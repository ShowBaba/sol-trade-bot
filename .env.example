# Solana (required)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional
JUPITER_API_KEY=
PORT=8080

# Redis (optional; if set, state + logs persist in Redis)
REDIS_URL=redis://redis:6379/0
REDIS_DB=0

# Live mode (optional)
# WALLET_KEYPAIR_PATH=./wallet.json
# WALLET_KEYPAIR_BASE64=
# DRY_RUN_LIVE=0
# CONFIRM_TIMEOUT_SEC=60
